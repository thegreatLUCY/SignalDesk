# Copy to .env and fill in. .env is gitignored (never committed).
# Phase 1 needs none of these yet — they document the contract for later phases.

# --- LLM provider chain (Phase 6): Groq -> OpenRouter -> templated fallback ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Macro (Phase 10): FRED, free API key from fred.stlouisfed.org ---
# Optional: everything works without it; the macro tab shows '—' and the
# briefing simply omits macro context until a key is present.
FRED_API_KEY=

# --- Frontend -> backend wiring ---
# The browser calls the backend directly; this is the base URL it uses.
NEXT_PUBLIC_API_BASE=http://localhost:8081

# --- Daily cron (Phase 6) ---
CRON_TZ=America/New_York
CRON_TIME=10:30
